# ---- RagAI backend configuration ----
# Copy to .env and fill in. Do NOT commit the real .env or credentials.json.

# --- MongoDB (online users) ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority

# --- Auth ---
# Generate a strong value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production

# --- Google Cloud / Vertex AI (online RAG) ---
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
# Path to a service-account key file. Optional on GCP instances that use
# Application Default Credentials (attached service account / workload identity).
CREDENTIALS_PATH=credentials.json
# Alternative for hosts without a mounted file (e.g. Azure): paste the entire
# service-account key JSON as a single-line secret. Takes precedence over CREDENTIALS_PATH.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account", ...}
# Gemini model used by the ADK agent.
MODEL_ID=gemini-2.5-flash

# --- Server ---
# Comma-separated allowed origins, or "*" for all. Lock this down in production.
CORS_ORIGINS=*

# --- Offline mode (optional; staged, not yet wired) ---
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_LLM_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text
# CHROMA_PATH=./data/chroma
